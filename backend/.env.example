# Real social publishing is disabled by default.
ENABLE_REAL_PUBLISHING=false
PUBLIC_ASSET_BASE_URL=https://YOUR_DOMAIN_HERE

# Meta Graph API for Facebook Page and Instagram Business publishing.
META_GRAPH_VERSION=v20.0
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# X API v2 user-context bearer token for tweet publishing.
X_BEARER_USER_TOKEN=

# Optional later: OAuth 1.0a credentials for X media upload or expanded flows.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
